---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/astro/SectionHeading.astro';
import { ui } from '../../utils/i18n';

const page = ui.en.pages.stack;
const groups = page.groups;
---

<BaseLayout lang="en" title={page.title} description={page.description}>
  <section class="page-container section-spacing px-6 pt-14">
    <SectionHeading eyebrow={page.eyebrow} title={page.heading} description={page.description} />
    <div class="mt-10 grid gap-6 lg:grid-cols-2">
      {Object.entries(groups).map(([group, items]) => (
        <article class="surface-panel rounded-[2rem] p-6 md:p-8">
          <p class="eyebrow">{group}</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {items.map((item) => (
              <span class="pill">{item}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>