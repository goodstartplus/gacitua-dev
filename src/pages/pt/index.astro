---
import { Image } from 'astro:assets';
import ActionLink from '../../components/astro/ActionLink.astro';
import SocialLinks from '../../components/astro/SocialLinks.astro';
import ProjectCard from '../../components/astro/ProjectCard.astro';
import SectionHeading from '../../components/astro/SectionHeading.astro';
import ProjectPreviewModal from '../../components/react/ProjectPreviewModal';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ui } from '../../utils/i18n';
import { getFeaturedProjects, getProjectsByLocale } from '../../utils/projects';

const allProjects = await getProjectsByLocale('pt');
const featuredProjects = await getFeaturedProjects('pt');
const home = ui.pt.home;
const stats = [
  { value: '06', label: 'Concluídos', dot: '#4ade80' },
  { value: '02', label: 'Em andamento', dot: '#facc15' },
  { value: '02', label: 'Planejados', dot: '#6b7280' },
];

const highlightItems = home.highlightItems;
const profileMeta = home.profileMeta;
const profileActions = [
  { href: '/pt/projects/', label: home.profileActions[0] },
  { href: '/pt/about', label: home.profileActions[1] },
  { href: '/pt/stack', label: home.profileActions[2] },
  { href: '/pt/contact', label: home.profileActions[3] },
];

const modalProjects = allProjects.map((project) => ({
  title: project.data.title,
  slug: project.data.slug,
  type: project.data.type,
  status: project.data.status,
  summary: project.data.summary,
  shortDescription: project.data.shortDescription,
  stack: project.data.stack,
  tags: project.data.tags,
  coverImage: project.data.coverImage,
  externalUrl: project.data.externalUrl,
  year: project.data.year,
  clientOrPersonal: project.data.clientOrPersonal,
}));
---

<BaseLayout
  lang="pt"
  title="André Gacitua — Perfil de Builder e Projetos"
  description="Homepage bilíngue de André Gacitua, apresentando produtos digitais, sistemas, websites, automações e um arquivo de projetos orientado a perfil."
>
  <section class="page-container section-spacing px-6 pt-6 md:pt-20">
    <div class="surface-panel hero-shell md:rounded-[2rem] md:p-10">
      <div class="hero-simple-layout">
        <div class="hero-simple-top">
          <div class="hero-identity">
            <div class="profile-avatar hero-profile-avatar overflow-hidden">
              <Image
                src="/images/profile/andre-gacitua.png"
                alt="André Gacitua"
                width={1200}
                height={1200}
                class="h-full w-full object-cover"
              />
            </div>
            <div>
              <p class="eyebrow">{home.heroEyebrow}</p>
              <h1 class="hero-name hero-name-large mt-3 text-white">{home.heroHeading}</h1>
              <div class="hero-stats hero-stats-inline hero-stats-simple hero-stats-under-name mt-6 grid grid-cols-3 gap-4">
                {stats.map((stat) => (
                  <div class="stat-card">
                    <span class="stat-value">{stat.value}</span>
                    <span class="stat-label">
                      <span class="stat-dot" style={`background: ${stat.dot}`} />
                      {stat.label}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <div class="hero-main">
          <p class="body-large hero-description hero-description-simple text-white/90">
            {home.heroDescription}
          </p>

          <div class="mt-8 flex flex-wrap items-center gap-3">
            <SocialLinks />
            <ActionLink href="/pt/about" variant="secondary" label={home.heroSecondary} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="page-container px-6 pb-2">
    <h2 class="mb-6 text-2xl font-semibold tracking-tight text-white">Projetos</h2>
    <div class="grid-instagram">
      {allProjects.map((project) => <ProjectCard project={project} modalEnabled />)}
    </div>
  </section>


  <section id="design-foundation" class="page-container section-spacing px-6 pb-6">
    <SectionHeading
      eyebrow={home.foundationEyebrow}
      title={home.foundationTitle}
      description={home.foundationDescription}
    />

    <div class="mt-8 flex flex-wrap gap-3">
      {highlightItems.map((item) => (
        <span class="pill">{item}</span>
      ))}
    </div>

    <div class="mt-8 grid gap-4 lg:grid-cols-3">
      <div class="surface-panel rounded-[1.75rem] p-6 lg:col-span-2">
        <p class="eyebrow">{home.visualIntent}</p>
        <p class="body-copy mt-4 max-w-2xl">{home.visualIntentCopy}</p>
      </div>
      <div class="surface-panel rounded-[1.75rem] p-6">
        <p class="eyebrow">{home.responsiveRule}</p>
        <p class="body-copy mt-4">{home.responsiveRuleCopy}</p>
      </div>
    </div>
  </section>

  <section id="featured-projects" class="page-container section-spacing px-6 pt-6">
    <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <SectionHeading
        eyebrow={home.featuredEyebrow}
        title={home.featuredTitle}
        description={home.featuredDescription}
      />
      <span class="muted-label text-sm">{featuredProjects.length} {home.featuredCountSuffix}</span>
    </div>

    <div class="grid-instagram">
      {featuredProjects.map((project) => <ProjectCard project={project} modalEnabled />)}
    </div>
  </section>

  <ProjectPreviewModal client:load projects={modalProjects} locale="pt" />

  <section id="about-builder" class="page-container section-spacing px-6 pb-6">
    <div class="grid gap-4 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="surface-panel rounded-[2rem] p-6 md:p-8">
        <SectionHeading
          eyebrow={home.aboutEyebrow}
          title={home.aboutTitle}
          description={home.aboutDescription}
        />
      </div>
      <div class="surface-panel rounded-[2rem] p-6 md:p-8">
        <p class="eyebrow">{home.profileActionsTitle}</p>
        <div class="mt-5 flex flex-wrap gap-3">
          {profileActions.map((action) => (
            <ActionLink href={action.href} variant="secondary" label={action.label} />
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="stack-overview" class="page-container px-6 pb-6">
    <div class="surface-panel rounded-[2rem] p-6 md:p-8">
      <div class="mb-6 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <SectionHeading
          eyebrow={home.stackEyebrow}
          title={home.stackTitle}
          description={home.stackDescription}
        />
      </div>
      <div class="flex flex-wrap gap-3">
        {['Astro', 'TypeScript', 'Cloudflare', 'React', 'Firebase', 'WordPress', 'Node.js'].map((item) => (
          <span class="pill">{item}</span>
        ))}
      </div>
    </div>
  </section>

  <section id="contact-entry" class="page-container section-spacing px-6 pt-4">
    <div class="surface-panel rounded-[2rem] p-6 md:p-8">
      <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-end">
        <SectionHeading
          eyebrow={home.contactEyebrow}
          title={home.contactTitle}
          description={home.contactDescription}
        />
        <ActionLink href="mailto:hello@example.com" variant="primary" label="hello@example.com" />
      </div>
    </div>
  </section>
</BaseLayout>