---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'left' } = Astro.props;
const alignmentClass = align === 'center' ? 'text-center items-center' : 'text-left items-start';
---

<div class={`flex flex-col gap-4 ${alignmentClass}`}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class="section-title max-w-3xl text-white">{title}</h2>
  {description && <p class="body-copy max-w-2xl">{description}</p>}
</div>