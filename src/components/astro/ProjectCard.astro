---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

interface Props {
  project: CollectionEntry<'projects'>;
  modalEnabled?: boolean;
}

const { project, modalEnabled = false } = Astro.props;
---

<article class="grid-card p-3 md:p-4" data-project-card data-project-type={project.data.type} data-project-status={project.data.status} data-project-trigger={modalEnabled ? true : undefined} data-project-slug={modalEnabled ? project.data.slug : undefined}>
  <div class="image-frame">
    <Image
      src={project.data.coverImage}
      alt={project.data.title}
      width={1600}
      height={1600}
      class="h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/25 to-black/10"></div>
    <div class="noise-overlay"></div>
    <div class="absolute inset-x-4 top-4">
      <span class="pill">{project.data.type}</span>
    </div>
    <div class="absolute inset-x-4 bottom-4">
      <p class="text-sm uppercase tracking-[0.18em] text-neutral-400">{project.data.clientOrPersonal}</p>
      <h3 class="mt-2 text-2xl font-semibold tracking-tight text-white">{project.data.title}</h3>
    </div>
  </div>

</article>