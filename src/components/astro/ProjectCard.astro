---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

interface Props {
  project: CollectionEntry<'projects'>;
  modalEnabled?: boolean;
}

const { project, modalEnabled = false } = Astro.props;
---

<article class="grid-card p-3 md:p-4" data-project-card data-project-type={project.data.type} data-project-status={project.data.status} data-project-trigger={modalEnabled ? true : undefined} data-project-slug={modalEnabled ? project.data.slug : undefined}>
  <div class="image-frame">
    <Image
      src={project.data.coverImage}
      alt={project.data.title}
      width={1600}
      height={1600}
      class="h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/25 to-black/10"></div>
    <div class="noise-overlay"></div>
    <div class="absolute inset-x-4 top-4 flex items-start justify-between gap-3">
      <span class="pill">{project.data.type}</span>
      <span class="rounded-full border border-white/10 bg-black/30 px-3 py-1 text-[0.7rem] uppercase tracking-[0.16em] text-neutral-300">
        {project.data.year}
      </span>
    </div>
    <div class="absolute inset-x-4 bottom-4">
      <p class="text-sm uppercase tracking-[0.18em] text-neutral-400">{project.data.clientOrPersonal}</p>
      <h3 class="mt-2 text-2xl font-semibold tracking-tight text-white">{project.data.title}</h3>
      <p class="mt-3 max-w-xs text-sm leading-7 text-neutral-300">{project.data.shortDescription}</p>
    </div>
  </div>

  <div class="mt-3 flex flex-wrap gap-2 px-1 pb-1">
    {project.data.tags.map((tag: string) => (
      <span class="rounded-full border border-white/10 px-3 py-1 text-xs text-neutral-300">{tag}</span>
    ))}
  </div>
</article>